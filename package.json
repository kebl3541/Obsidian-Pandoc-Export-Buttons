{
  "name": "pandoc-export-buttons",
  "version": "1.1.2",
  "description": "One-click buttons that export the current Obsidian note to any format Pandoc supports.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && node deploy.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "pandoc",
    "export"
  ],
  "author": "kebl3541",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.4.11",
    "typescript": "^5.3.3"
  }
}
